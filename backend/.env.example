# Copy to .env and fill in values

# Required: OpenAI API key
OPENAI_API_KEY=sk-proj-your-key-here

# Required: PostgreSQL connection string (set automatically by Railway Postgres plugin)
# For local dev, you can use SQLite by leaving this unset (falls back to seasoning.db)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required in production: random secret for JWT signing
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
